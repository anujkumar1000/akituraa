# ─────────────────────────────────────────────
# AKITAURAA — Environment variables
# Copy to .env and fill in. Never commit .env.
# ─────────────────────────────────────────────

# Database (PostgreSQL — e.g. Neon, Supabase, Railway)
DATABASE_URL="postgresql://user:password@localhost:5432/akitauraa?schema=public"

# App
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="AKITAURAA"

# Razorpay (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# Cloudinary (image + video hosting)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Auth (NextAuth / Auth.js — add when wiring accounts)
AUTH_SECRET=""

# Admin bootstrap
ADMIN_EMAIL="hello@akitauraa.com"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  description    String?
  image          String?
  parentId       String?
  seoTitle       String?
  seoDescription String?
  sortOrder      Int        @default(0)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  parent         Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children       Category[] @relation("CategoryTree")
  products       Product[]

  @@index([slug])
  @@index([parentId])
}

model Collection {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  description    String?
  image          String?
  seoTitle       String?
  seoDescription String?
  isFeatured     Boolean   @default(false)
  isActive       Boolean   @default(true)
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  products       Product[] @relation("ProductCollections")

  @@index([slug])
}

model Product {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  sku            String           @unique
  description    String
  handmadeStory  String?
  materials      String?
  weight         String?
  dimensions     String?
  shippingInfo   String?
  price          Int
  salePrice      Int?
  currency       String           @default("INR")
  isFeatured     Boolean          @default(false)
  isBestseller   Boolean          @default(false)
  isNewArrival   Boolean          @default(false)
  isActive       Boolean          @default(true)
  inventory      Int              @default(0)
  lowStockAt     Int              @default(5)
  trackInventory Boolean          @default(true)
  categoryId     String
  ratingAvg      Float            @default(0)
  ratingCount    Int              @default(0)
  soldCount      Int              @default(0)
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  orderItems     OrderItem[]
  category       Category         @relation(fields: [categoryId], references: [id])
  images         ProductImage[]
  variants       ProductVariant[]
  videos         ProductVideo[]
  reviews        Review[]
  wishlistItems  WishlistItem[]
  collections    Collection[]     @relation("ProductCollections")
  tags           Tag[]            @relation("ProductTags")
  Product_A      Product[]        @relation("RelatedProducts")
  Product_B      Product[]        @relation("RelatedProducts")

  @@index([slug])
  @@index([categoryId])
  @@index([isFeatured])
  @@index([isBestseller])
  @@index([isNewArrival])
  @@index([price])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVideo {
  id        String  @id @default(cuid())
  productId String
  url       String
  poster    String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  name       String
  value      String
  priceDelta Int     @default(0)
  inventory  Int     @default(0)
  sku        String? @unique
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Tag {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  products Product[] @relation("ProductTags")
}

model Customer {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  phone        String?
  passwordHash String?
  role         Role       @default(CUSTOMER)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  addresses    Address[]
  orders       Order[]
  reviews      Review[]
  wishlists    Wishlist[]

  @@index([email])
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  fullName   String
  phone      String
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  country    String   @default("India")
  isDefault  Boolean  @default(false)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Order {
  id                String        @id @default(cuid())
  orderNumber       String        @unique
  customerId        String?
  guestEmail        String?
  guestPhone        String?
  status            OrderStatus   @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  subtotal          Int
  discount          Int           @default(0)
  shipping          Int           @default(0)
  total             Int
  couponId          String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  shippingAddress   Json?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  coupon            Coupon?       @relation(fields: [couponId], references: [id])
  customer          Customer?     @relation(fields: [customerId], references: [id])
  items             OrderItem[]

  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  name      String
  image     String?
  unitPrice Int
  quantity  Int
  variant   String?
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model Review {
  id         String    @id @default(cuid())
  productId  String
  customerId String?
  authorName String
  rating     Int
  title      String?
  body       String?
  images     String[]
  isVerified Boolean   @default(false)
  isApproved Boolean   @default(false)
  createdAt  DateTime  @default(now())
  customer   Customer? @relation(fields: [customerId], references: [id])
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Wishlist {
  id         String         @id @default(cuid())
  customerId String?
  name       String         @default("My Wishlist")
  shareToken String         @unique @default(cuid())
  isPublic   Boolean        @default(false)
  createdAt  DateTime       @default(now())
  customer   Customer?      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items      WishlistItem[]

  @@index([customerId])
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
}

model Coupon {
  id          String       @id @default(cuid())
  code        String       @unique
  type        DiscountType
  value       Int
  minSubtotal Int          @default(0)
  maxUses     Int?
  usedCount   Int          @default(0)
  startsAt    DateTime?
  expiresAt   DateTime?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  orders      Order[]

  @@index([code])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model BlogPost {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  excerpt        String?
  body           String
  coverImage     String?
  author         String    @default("AKITAURAA")
  tags           String[]
  isPublished    Boolean   @default(false)
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([slug])
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENT
  FIXED
  FREE_SHIPPING
}
